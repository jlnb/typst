@TechReport{Tuschhoff2018,
  author   = {Tuschhoff, Matthias},
  title    = {Cylinder for hydraulic gap control (HGC) — Hysteresis test},
  year     = {2018},
  month    = jan,
  abstract = {The attached figure shows the result of a hysteresis test for a HGC cylinder.
During the test the cylinder was installed in our test facility. This test equipment
restricts the cylinder movement by a frame similar to a small mill stand housing.
Therefore hysteresis tests can be performed at the full range of cylinder forces.
The hydraulic pressures at the piston side and ring side have been measured and
recorded. The cylinder was equipped with two position transducers to measure
the stroke. The graph shows the cylinder force calculated from the measured
pressures versus the average cylinder stroke.
The recorded hysteresis is displayed as solid blue line which shows the typical
characteristics of a hysteresis. Green arrows indicate the run of time during the
test. During the first phase of increasing force the cylinder force is higher than
during the second phase which might be due to setting effects within the test
stand equipment. For the evaluation of the friction the second phase will be
considered. During the test the ring side pressure amounts to about 50 bar (5
MPa), the piston side pressure was close to 280 bar (28 MPa).
The center line of the hysteresis loop indicates the elastic behavior of the test
equipment. The difference between this line and the measured force is due to
the friction of the cylinder. This is evaluated at one position for the phase of
increasing force.
The friction force amounts to about 55 kN. This is below our target value of
75 kN. Therefore the friction of the cylinder is within the acceptable range.},
  file     = {:Tuschhoff/Tuschhoff2018.pdf:PDF},
  groups   = {Monitoring, Hydraulik},
  keywords = {HGC, Hysterese, Zylindertest, Hydraulik, Testbeschreibung, Reibung, friction},
}

