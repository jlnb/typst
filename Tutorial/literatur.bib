@TechReport{Haberkamm1987a,
  author   = {Haberkamm, Klaus-Dieter},
  title    = {Hydraulische Anstellung - Einfluss der Leitungslaenge zwischen Servoventil und Zylinder auf das dynamische Verhalten},
  year     = {1987},
  abstract = {In der folgenden Ausarbeitung wird gezeigt, dass die Laenge der
Verbindungsrohrleitung zwischen Servoventil und Anstellzylinder
das Reaktionsverhalten einer Hydraulischen Anstellung wesentlich
bestimmt. Es muss darauf hingewiesen werden, dass es sich bei allen errech-
neten Zahlen um theoretische Werte handelt, die im Walzbetrieb
nur bei optimalen Bedingungen erreicht werden koennen. Dieser Zu-
stand wird ueber einen laengeren Zeitraum niemals moeglich sein.
Unabhaengig davon koennen jedoch die einzelnen Ergebnisse unter-
einander verglichen werden. Die Basislaenge ist mit 3,0 m
(ca. 10 ft.) eingesetzt. Bei Verdoppelung dieser Laenge steigt die Anregelzeit auf mehr als das
Doppelte. Die Anregelzeit und das Ausregelverhalten bestimmen die
Stabilitaet und die Wirksamkeit ueberlagerter Regelkreise
(Dickenregelung). Ein weiteres Kriterium sind Reaktionen auf sinusfoermige Sollwerte
und Stoerungen. Auch hier zeigt sich, dass mit steigender Laenge
die Reaktionen schlechter werden. Extrem kurze Leitungen haben im vorliegenden Fall wiederum keine
entscheidend positive Auswirkungen, da die dynamischen Reaktionen
natuerlich von weiteren Parametern, Z. B. dem gegebenen Geruest-
eigenverhalten oder Zeitverhalten des vorgesehenen Servoventils
bestimmt werden. An dem Beispiel von Anstichvorgaengen werden weitere Beurteilungs-
kriterien aufgezeigt. Auch hier hat eine laengere Leitung Nachteile.},
  file     = {:Haberkamm/Haberkamm1987a.pdf:PDF},
  groups   = {Hydraulik},
  keywords = {Angebot Nr.60700218, Hydraulik, Schwingungen, Leitungslaenge, HGC, Zylinder},
}

