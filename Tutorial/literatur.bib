@Article{Bhaumik2016,
  author   = {Bhaumik, Sanat},
  journal  = {Steel Technology},
  title    = {Preferred Technology for Production of 1.0 Mtpy Ultra Thin HR Coils},
  year     = {2016},
  abstract = {There are four proven routes for production of hot rolled coils
(HRC) and these are: (1) Steckel Mill route, (2) Conventional
Hot Strip Mill (HSM) route (3) Thin Slab Casting & Rolling Mill
(CSP or QSP) route and (4) Endless Strip Production (ESP) route.
Selection of right production process technology will depend on
the product mix (strip thickness, width & steel grades), product
quality and production capacity of the plant.
For example, a 2-stand steckel mill will be able to produce about
0.75 — 0.80 million tonnes of HRC per year (mtpy) if we consider
1250 mm maximum width strips. Again, the steckel mill cannot
produce HRC of less than 1.8 mm strip thickness on consistent
basis. Even with implementation of latest automation hardware
and software systems, the thickness and flatness tolerances on
output HRC from steckel mills will be below market average
considering the outputs from other units like conventional HSM,
CSP®/QSP or Arvedi ESP.
Conventional Hot Strip Mill (HSM) can produce minimum
strip thickness of 1.2 mm, but the optimum production capacity
will be approximately 2.8 to 3.0 mtpy of HRC if we consider 1250
mm maximum width strip. Annual production capacity of less
than 2.5 mtpy will make such plant economically unviable.
For the same strip width of 1250 mm, a thin slab casting &
rolling mill (CSP® or QSP) will be able to produce 1.0 mtpy with
a single casting strand, which can be doubled by adding the 274
casting strand in the future. The CSP® (Compact Strip Plant)
or QSP (Quality Strip Production) route can produce minimum
strip thickness of 1.2 mm on a regular basis and is being produced
by many plants worldwide, but some of them are also claiming
production of even 1.0 mm thickness.
An Arvedi ESP
(Endless
Strip Production)
can produce
ultra-thin HRC of 0.80 mm thickness and undoubtedly the best
technology available for the production of ultra-thin HRC on a
consistent basis with very good thickness and shape tolerances.
However, an Arvedi ESP will be able to produce a maximum 1.0
- 1.20 mtpy HRC for 1250 mm maximum width, but there is no
possibility of production capacity expansion of the same plant in
the future.
Before we reach a final conclusion for the best production
route for 1.0 mtpy thin 1250 mm wide HRC production suitable
for application in markets like Bangladesh, let us have a look at
these four processes and technology.},
  file     = {:Bhaumik/Bhaumik2016.pdf:PDF},
  keywords = {Primetals},
}

@Article{Pigani2016,
  author   = {Pigani, Alessandro and Bobig, Paolo and Knights, Mike and Martinis, Stefano},
  journal  = {BHM Berg- und Hüttenmännische Monatshefte},
  title    = {Danieli Universal Endless (DUE)},
  year     = {2016},
  issn     = {1613-7531},
  number   = {9},
  pages    = {429--439},
  volume   = {161},
  abstract = {Over the last 25 years, the thin slab casting and rolling process has been gaining a major market share in the production of hot rolled strip, progressively eroding the areas previously of exclusive domain of conventional mills.

This is mainly thanks to the competitiveness of the process over conventional ones and to the growing ability of this technology to cover the majority of market niches well beyond the boundaries of the commodity market.

After having significantly contributed to the continuous expansion of this production mode and after an extensive campaign of research and physical testing in reference plants, Danieli has progressively developed a new generation of thin slab casting and rolling layout over the years, marking a new phase in the evolution of this process.

The new step-ahead is a new development within the Quality Strip Production (QSP) family, which is the Danieli’s strip-quality-oriented thin slab based plants.

What makes this new concept different is the ability of “universal” rolling modes thanks to the fact that now, within one single plant, it is possible to perform different rolling modes, making this plant a major technology innovation compared to the previous generation.

This new approach can be seen as the natural evolution of the original successful Danieli concepts that marked the progress of the thin slab route, namely the application of the vertical curved design thin slab caster and the separation of the rolling stands into high reduction units and finishing units.

In den letzten 25 Jahren hat das Dünnbrammen-Gieß- und Walzverfahren einen großen Marktanteil bei der Herstellung von Warmbändern gewonnen, die in der Vergangenheit ausschließlich die Domäne von konventionellen Stranggieß- und Warmwalzwerken waren.

Dies beruht vor allem auf der Wettbewerbsfähigkeit des Verfahrens gegenüber herkömmlichen Verfahren und auf der wachsenden Fähigkeit dieser Technologie, die Mehrheit der Marktnischen weit über die Grenzen des Rohstoffmarktes hinaus abzudecken.

Durch den kontinuierlichen Ausbau des Produktionsmodus und nach einer umfangreichen Kampagne für die Forschung und physikalischen Tests in Referenzanlagen hat Danieli im Laufe der Jahre schrittweise eine neue Generation von Dünnbrammen-Gieß- und Walztechnologien entwickelt, was eine neue Phase in der Entwicklung dieses Prozesses darstellt.

Der neue Innovationsschritt ist eine Entwicklung in der Technologiefamilie Quality Strip Production (QSP), welche die qualitätsorientierten Dünnbrammenanlagen von Danieli darstellt.

Mit diesem neuen Konzept des universellen Walzens können verschiedene Walzstrategien mit einer einzigen Anlage ausgeführt werden. Diese Anlage ist daher eine große technologische Innovation im Vergleich zur vorherigen Generation.

Dieser neue Ansatz kann als die natürliche Evolution des ursprünglichen erfolgreichen Danieli Konzepts gesehen werden, das den Fortschritt der Dünnbrammenroute darstellt, nämlich die Anwendung des vertikal geschwungenen Designs in der Dünnbrammengießanlage und die Trennung der Walzstraße in Vor- und Endgerüste.},
  doi      = {10.1007/s00501-016-0521-3},
  file     = {:Pigani/Pigani2016.pdf:PDF},
  refid    = {Pigani2016},
  url      = {https://doi.org/10.1007/s00501-016-0521-3},
}

@Article{Fraser2016,
  author   = {Fraser, J. and Scott, B. and Brousseau, R. and Alligood, M.},
  journal  = {AISTECH},
  title    = {Reliability Engineered Rolling Mill Drivelines for Maximum Performance},
  year     = {2016},
  abstract = {The increasing number of technical possibilities for connecting an almost arbitrary number of objects may lead to a variety of effects on product development and production as well as on people’s private lives. The basis for a beneficial utilization is the integration of more and more distributed computers (“Cyberspace”) and physical objects (“Physical Systems“). To master the complexity of production processes and systems, it helps to investigate them on a superordinate system level. From this point of view, production systems realize multiple transformations of product properties. Detailed knowledge about these transformations is necessary to comply with the increasing requirements on product quality. Appropriate models of all production steps in the sense of a seamless model-based production are needed. The final goal is to predict and to achieve required product properties in the best way possible.

Durch die zunehmenden technischen Möglichkeiten der Vernetzung sind vielfältige Auswirkungen auf Produktentwicklung und Produktion sowie auf unser Privatleben zu erwarten. Basis für eine vorteilhafte Nutzung bildet die Integration von zunehmend verteilten Computern („Cyberspace“) und physischen Objekten („Physical Systems“).

Aus Systemsicht betrachtet, realisieren Produktionssysteme mehrstufige Transformationen von Produkteigenschaften. Um den steigenden Anforderungen an die Produktqualität zu begegnen, ist eine möglichst detaillierte Kenntnis dieser Transformationen erforderlich. Dazu werden geeignete Modelle aller einzelnen Produktionsschritte im Sinne einer nahtlosen, Modell-basierten Produktion benötigt. Ziel ist es, geforderte Produkteigenschaften möglichst gut vorherzusagen und letztendlich zu erreichen},
  file     = {:Fraser/Fraser2016.pdf:PDF},
  keywords = {voestalpine Stahl GmbH, Primetals},
}

