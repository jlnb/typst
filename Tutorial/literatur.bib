@Article{Spera2016,
  author   = {Spera, S. and Woodward, D. and Winter, B.},
  journal  = {Iron and Steel Technology},
  title    = {Replacing obsolete speed and position sensors in metals applications},
  year     = {2016},
  month    = {12},
  pages    = {36-43},
  volume   = {13},
  abstract = {Obsolete speed and position sensors in metals operations are a significant source of downtime.
This paper explores the
causes of this downtime, and offers specific remedies and processes to reduce or eliminate this downtime.
With the huge growth of emerging economies and the globalization of metals production as
showcase”, metals firms worldwide have seen constant downward pressure on per-ton pricing. a “technological prestige
All metals firms are
simultaneously experiencing constant upward pressure on quality and product grades.
The worldwide capacity glut
is
producing tremendous pressure on
all mills.
“According
to (Anthony) de Carvalho (from the OECD’s steel unit) the
profitability of the steel industry is unsustainably weak, trade friction in the sector is increasing™'. These forces have driven
legacy metals operations
to become incredibly lean and efficient operations.
Typically this lean focus causes capital
equipment lifecycles to be stretched, and stretched again.
As a result, legacy mills and processing operations have a much
wider equipment age span’.
The average age of legacy mill machinery
is
far higher than their counterparts in newly
developing economies.
Today’s lean metals operations don’t have the huge maintenance staff that may have been possible 40 years ago®.
This
maintenance staff may no longer have longevity with their plant or sections within their area of responsibility*.
Scheduled
maintenance and downtime avoidance is a goal but often speed and position sensors are replaced only when they fail.
Bottom line: older mills have a huge range of speed and position sensors installed on them. This huge range of devices often
includes obsolete devices both known and unknown.
This paper outlines methods for identifying and systematically
replacing mission-critical speed and position sensors.
This will reduce sensor-related downtime dramatically in metals
operations.},
  file     = {:Spera/Spera2016.pdf:PDF},
}

@Article{Yan2019,
  author   = {Yan, Xiao-qiang and Qi, Jie-bin and Wang, Xin-xin},
  journal  = {Journal of Iron and Steel Research International},
  title    = {An active method suppressing rolling mill vibration: disturbance estimation and compensation algorithm},
  year     = {2019},
  issn     = {2210-3988},
  number   = {7},
  pages    = {697--703},
  volume   = {26},
  abstract = {The rolling mill vibration not only seriously causes the strip thickness heterogeneity, but also damages the rolling mill equipment and its electrical components. Existing vibration suppression methods are passive and mainly tune mechanical, hydraulic, electrical and rolling process parameters. A new active vibration suppression method was thus proposed using the disturbance estimation and compensation algorithm. Firstly, the hydraulic-mechanical coupling model of the rolling mill vibration was established, and an active vibration suppressor was designed based on the extended state observer. Then, through the numerical simulation, it is found that the vibration energy is reduced by 35.3% using the vibration suppressor, and the vibration suppressor is valid when the vibration frequency is lower than 60 Hz. Finally, the vibration suppressor was applied to the in-site manufacturing, and the expected vibration suppression was obtained. The method makes the produced steel strip have more uniform thickness and further significantly increases the finished product ratio.},
  doi      = {10.1007/s42243-019-00300-3},
  file     = {:Yan/Yan2019.pdf:PDF},
  refid    = {Yan2019},
  url      = {https://doi.org/10.1007/s42243-019-00300-3},
}

