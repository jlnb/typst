@InProceedings{ThyssenKruppStahl2001,
  author   = {Thyssen Krupp Stahl AG},
  title    = {Apperance of surface defect at hot strip 2001},
  year     = {2001},
  month    = jun,
  abstract = {Qualitätskontrolle von Oberflächenfehlern im Warmband
Kapitel 1: Rauheit und Zunderporen
Feine Rauheit (Fehler Nr. 1)

Ort: Unregelmäßig über die Bandbreite, gleichmäßig über die Länge.
Erkennungsstufe: Geätzte Probe in der Haspelgrube oder am Ausgang der Beizlinie.
Bemerkungen: Wird nicht als Fehler betrachtet; steht für eine gute Oberflächenqualität.
Mittlere Rauheit (Fehler Nr. 2)

Ort: Unregelmäßig über die Bandbreite, gleichmäßig über die Länge.
Ursache: Leichter Verschleiß der Arbeitswalzen im Fertigwalzwerk.
Bemerkungen: Keine Abhilfe erforderlich; für alle Anwendungen geeignet.
Starke Rauheit (Fehler Nr. 3)

Ort: Unregelmäßig über die Bandbreite, Intensität kann von Bandende zu Bandanfang zunehmen.
Ursache: Raue Arbeitswalzen in den ersten Ständen oder andere mögliche Ursachen.
Abhilfe: Entlastung des betroffenen Walzgerüsts oder Austausch der rauen Arbeitswalzen.
Feine Zunderporen (Fehler Nr. 4)

Ort: Unregelmäßig über die Breite, Intensität kann von Bandende zu Bandanfang zunehmen.
Ursache: Teilweise unbekannt; beeinflusst durch Walzenrauheit, Stichabnahmen, Walztemperaturen und Elementzusammensetzung (z.B. P, Mn, S, As).
Abhilfe: Behandlung der Walzenrauheit oder Austausch der verschlissenen Walzen.
Weitere Kapitel
Das Dokument führt weitere Fehler auf, wie Zunderflecken, Walzstaub und andere Eindrücke oder Markierungen, die von bestimmten Walzständen oder Prozessen stammen. Jeder Fehler wird mit seinem Ort, der Erkennungsstufe, möglichen Ursachen und empfohlenen Abhilfen beschrieben.

Allgemeine Beobachtungen
Erkennung: Viele Fehler werden in der Beizstufe erkannt, was die Bedeutung dieses Prozesses in der Qualitätskontrolle unterstreicht.
Ursachen und Abhilfen: Häufige Ursachen sind Walzenverschleiß und Prozessparameter wie Temperatur und Stichabnahme. Abhilfen beinhalten oft Wartungsmaßnahmen wie den Austausch von Walzen oder Prozessanpassungen.
Fazit
Der Katalog dient als umfassender Leitfaden zur Identifizierung, zum Verständnis und zur Behebung von Oberflächenfehlern in der Warmbandproduktion, um eine hohe Qualität für verschiedene Anwendungen sicherzustellen. Das Dokument betont die Bedeutung regelmäßiger Wartung und Prozesskontrolle, um Fehler zu minimieren.},
  file     = {:C\:/Users/olit/Downloads/einsortieren/ThyssenKrupp - WISCO - Apperance of surface defect at hot strip 2001.pdf:PDF},
  keywords = {Rauheit / Roughness;Zunderporen / Scale Pores;Oberfläche / Surface;Fehler / Defect;Warmband / Hot Strip;Arbeitswalzen / Work Rolls;Fertigwalzwerk / Finishing Mill;Erkennungsstufe / Detection Stage;Ursache / Cause;Abhilfe / Remedy;Beizlinie / Pickling Line;Verschleiß / Wear;Walzenrauheit / Roll Roughness;Stichabnahme / Reduction per Pass;Walztemperaturen / Rolling Temperatures;Elementzusammensetzung / Elemental Composition.},
}

@TechReport{Seidel2015,
  author   = {Jürgen Seidel},
  title    = {Walzspaltschmierung in Warmbandstraßen},
  year     = {2015},
  abstract = {Ein interner technischer Bericht, der sich auf die Entwicklung und Optimierung von Walzspaltschmiersystemen in Warmbandstraßen konzentriert. Nachfolgend finden Sie eine Zusammenfassung der wichtigsten Punkte auf Deutsch:

Aktueller Stand und Herausforderungen
Schmiermittelentwicklung:

SMS Demag lieferte traditionell die Komponenten für Walzspaltschmiersysteme, während Drittfirmen wie Quaker und Stuart die Schmiermittel bereitstellten.
Die Variabilität der Öleigenschaften aufgrund unterschiedlicher Lieferanten und Entwicklungen war während verschiedener Inbetriebnahmephasen problematisch.
Seit Juni 2008 arbeitet SMS Demag in einem Joint Venture mit einem Schmiermittellieferanten zusammen, um eigenes Öl zu produzieren und so das Gesamtsystem zu verbessern und zusätzlichen Wert zu schaffen.
Systemverbesserung:

Die Salzgitter AG hat die Modernisierung ihres bestehenden Walzspaltschmiersystems in Auftrag gegeben, das Probleme mit der Schmierwirkung über die Zeit und über die Breite aufweist.
Eine neue Reinigungseinheit wurde in das System integriert, um reproduzierbare Bedingungen zu gewährleisten und die Verstopfung der Rohre durch Verseifung zwischen Öl-Wasser-Mischer und Sprühdüsen zu verhindern.
Entwicklungsaufgaben
Schmiermittelentwicklung:

Entwicklung von Ölen für den Warmwalzprozess mit gleichwertigen oder besseren Eigenschaften als die der Konkurrenz.
Durchführung von Versuchen bei ThyssenKrupp Nirosta, einschließlich der Analyse von Ölproben, der Nachbildung von Konkurrenzölen und der Herstellung von alternativen Ölen mit verbesserten Eigenschaften.
Durchführung von Streifenziehversuchen zur Bestimmung der Reibwerte für einen relativen Vergleich verschiedener Öle.
Systemoptimierung:

Unterstützung bei der Inbetriebnahme des Walzspaltschmiersystems in Salzgitter, Optimierung der Ölmengen basierend auf dem Bandmaterial und anderen Bedingungen.
Festlegung der Reinigungsspezifikationen für das Schmiersystem und Anpassung der Automatisierung.
Zusammenfassung des Fortschritts
Walzspaltschmiersystem:

Das System wurde in Betrieb genommen und getestet, mit erfolgreicher Implementierung eines automatischen Reinigungssystems bei Salzgitter.
Das SMS-System zeigt eine verbesserte Reproduzierbarkeit im Vergleich zum Quaker-System, was die Bandstabilität erhöht und den Wartungsaufwand reduziert.
Schmiermittelentwicklung:

SMS Lubrication hat Konkurrenzöle analysiert und eigene Öle entwickelt, die erfolgreich in Walzwerken getestet wurden.
Tests bei ThyssenKrupp Nirosta zeigten, dass SMS-Öle besser als Quaker-Öle abschneiden, was die Oberflächenqualität verbessert.
Ein neues Öl, „PrimeLub HR 2000“, wurde mit reduzierter Verschmutzungsneigung entwickelt und steht für den Einsatz in konventionellen Warmbandstraßen wie Salzgitter bereit.
Technische Überlegungen
Arbeitswalzenkühl- und Schmiersystem:

Das System muss zusammen mit dem Walzenkühlsystem bewertet werden, um thermische Überlastung zu vermeiden und die Lebensdauer der Walzen zu verlängern.
Effiziente Walzenkühlung ist entscheidend, auch wenn die Kühlung auf der Einlaufseite abgeschaltet ist, um die Bandform nicht negativ zu beeinflussen.
Kühlsystemdesign:

Das Design umfasst einen vierreihigen Spritzbalken auf der Auslaufseite mit Merkmalen wie ausreichender Wassermenge, hohem Anpressdruck und großem Sprühwinkel für eine effektive Kühlung.},
  file     = {:Seidel/Seidel2015.pdf:PDF},
  keywords = {Schmiermittelentwicklung; Lubricant DevelopmentWalzspaltschmiersystem; Roll Gap Lubrication SystemReinigungseinheit; Cleaning UnitSystemoptimierung; System OptimizationInbetriebnahme; CommissioningReproduzierbarkeit; ReproducibilityStreifenziehversuche; Strip Drawing TestsVerschmutzungsneigung; Contamination Tendency; HSM},
}

