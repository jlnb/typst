@Article{Shimoda,
  author   = {Shimoda N. and Imanari, H, and Suzuki, A. and Sano, M. and Ohara, K.},
  title    = {Advanced Technologies of Process Control to Hot Strip Rolling Mill},
  abstract = {In this paper, we discuss two aspects of process technology improvement for “conventional” Hot Strip Mills.
The first aspect is strip temperature control. A finite difference method (FDM) is applied to calculate the strip
temperature distribution in each length element being rolled based on time, temperature distribution, and surface
energy flows. The distribution was originally modelled on the thickness axis only, but is now modelled on both
thickness and width axes to estimate and evaluate the temperature drop around the strip edges.
The second aspect is strip width control. It is important to model causes of width changes such as width spread by
thickness reduction, dog-bone recovery by edger rolling, and tension effect in finishing tandem mill rolling. By
combining an accurate prediction model of width changes with dynamic control along a bar we achieve highly
accurate and uniform product width.
We also show examples of calculation and control results applied to the online Hot Strip Mill systems.},
  file     = {:Shimoda/Shimoda.pdf:PDF},
  keywords = {Hot Strip Mill, Process control, Temperature control, Width control, Finite difference method, Prediction model, Mitsubishi-Electric, TMEIC},
}

@Article{Herbosch2015,
  author   = {Herbosch, Pascal},
  title    = {Reduction of the electrical consumption in the hot strip mill},
  year     = {2015},
  abstract = {The hot strip mill of ArcelorMittal Gent consists of a roughing mill with two stands (E2R2 and R3) andafinishing
mill of 7 stands and has an electrical consumption of more than 300 000 MWh/year. The main electrical consumers
are the motors of the finishing mill (45%), the motors of the roughing mill (20%) and the pumps for the water and oil
circuit (17%). The reduction of the electrical consumption is for years now an important topic in defining projects.
Using the methodology of WCM, through the pillar of Focused Improved, and with the commitment of the whole
team of the hot strip mill, several projects are defined and realized over the last years, reducing the electrical
consumption significantly: 5% compared to 2012. The most important projects to realize this are the installation of
variable speed drives on pumps for descaling and cooling, the optimal use of number of pumps, the change of the
main drives in the rolling process, the reduction of the pressure of the work roll cooling, the change of lubrication
system in the finishing mill, the optimization of the electrical consumption during stops by introducing a saving
mode and the detail-monitoring of the consumption. Some of these cases required no or little funding and are just
optimizations in the use of our installations, e.g. optimal use of pumps, follow-up of the detail-monitoring, saving
mode. To be emphasized is the need for a consequent and durable maintenance program to ensure the
sustainability of the realized optimizations. The hot strip mill of ArcelorMittal Gent is considered as a benchmark for
electricity consumption for years, and with the steps taken the last years this should be sustained..},
  file     = {:Herbosch/Herbosch2015.pdf:PDF},
  keywords = {Electrical consumption, energy, hot strip mill, ArcelorMittal, Gent, Belgium},
}

@Article{Marchiori2018,
  author   = {Marchiori, Francesca and Benini, Michele and Cateni, Sivia and Colla, Valentina and Ebel, Alexander and Neuer, Marcus and Piedimonte, Luca and Vignali, Antonella},
  journal  = {Stahl und Eisen},
  title    = {Agent-based approach for energy demand-side management},
  year     = {2018},
  month    = {02},
  volume   = {138},
  abstract = {The rise of renewable energy sources increases power fluctuations in the power network due to daily and seasonal effects which have sensible impacts on pricing and tariffs. According to the Smart Grid Initiative the closer cooperation between electrical energy suppliers, retailers, network operators and authorities on one side and consumers on the other side is generally considered as strategic key. Large users actually are implementing active actions devoted to the intelligent access to the grid introducing technologies and procedures for flexible load control. Within the steel industry, especially the electric steelmaking plants have an extremely high potential for load control and decrease of the carbon footprint of the global steel production. This paper presents an agent based approach providing the steel industry a possible solution for the exploitation of opportunities and challenges constituted by energy markets.},
  file     = {:Marchiori/Marchiori2018.pdf:PDF},
  keywords = {Renewable energy sources, power fluctuations, daily and seasonal effects, pricing and tariffs, Smart Grid Initiative, cooperation: energy suppliers, retailers, network operators, authorities, consumers, strategic key, flexible load control, intelligent grid access, steel industry, electric steelmaking plants, carbon footprint reduction, energy markets, agent-based approach, opportunities and challenges in energy markets, Deutsch:Erneuerbare Energiequellen, Netzschwankungen, tägliche und saisonale Effekte, Preise und Tarife, Smart-Grid-Initiative, Zusammenarbeit: Energieversorger, Einzelhändler, Netzbetreiber, Behörden, Verbraucher, strategischer Schlüssel, flexibles Lastmanagement, intelligenter Netzzugang, Stahlindustrie, elektrische Stahlerzeugung, Reduzierung des CO₂-Fußabdrucks, Energiemärkte, agentenbasierter Ansatz, Chancen und Herausforderungen auf Energiemärkten},
}

@Article{Scheidl2016,
  author   = {Scheidl, Rudolf and Winkler, Bernd and Kogler, Helmut and Ladner, Peter and Haas, Rainer and Lukachev, Evgeny},
  journal  = {BHM Berg- und Hüttenmännische Monatshefte},
  title    = {Digital Fluid Technologies for the Steel Industry},
  year     = {2016},
  issn     = {1613-7531},
  number   = {11},
  pages    = {504--509},
  volume   = {161},
  abstract = {Digital fluid systems are controlled solely by on-off valves, in contrast to analogue fluid systems which use continuously adjustable valves. Many digital fluid systems have been in practical use for some decades. The steel industry relies on several fluid technologies. Apart from the handling of the liquid steel, several other fluid processes exist to fulfill indispensable functions; examples include cooling, motion control, torch cutting, descaling, and lubricating. Many of these processes need better control concerning precision, dynamics, resource demand, reliability, and environmental impact or must offer additional functionalities for use in factories of the future. In several cases digital fluid systems are the better solutions. In this paper this is demonstrated by four examples, ranging from proven simple solutions and concepts going currently into industrial application to promising concepts for the future.},
  doi      = {10.1007/s00501-016-0541-z},
  file     = {:Scheidl/Scheidl2016.pdf:PDF},
  refid    = {Scheidl2016},
  url      = {https://doi.org/10.1007/s00501-016-0541-z},
}

@Article{Lu,
  author   = {Lu, Zijun and Imanari, Hiroyuki and Osaka, Yuka and Shinohara, Shutaro},
  title    = {All-in-one Energy Saving Solution in Steel Plant},
  abstract = {As one of the world’s most energy intensive industries, the metals industry needs to make more
effective use of
energy in the operation of steel-making facilities, rolling mills, and processing lines. In recent years, TMEIC has
developed several predictive energy saving solutions for fans and pumps in rolling mills which are able to save
more energy than conventional methods. Work on this energy saving solution has also highlighted how important it
is to raise awareness of energy management to encourage users to pursue ongoing energy savings. Based on a
new controller designed to integrate the functions of a PLC and process computer, an all-in-one energy saving
solution featuring sequential control, energy saving model calculation, energy visualization and energy analytics
was able to be implemented as a single package. In this paper, we discuss this all-in-one solution including the
energy management tools it provides and the individual energy saving solution for descaling pumps, main motor
cooling fans, and water treatment pumps.},
  file     = {:Lu/Lu.pdf:PDF},
  keywords = {Predictive energy saving solution, Energy management, Visualization, Analytics, New controller, All-in-one},
}

