}

@Article{Hlobil,
  author   = {Hlobil, Helmut and Gafur, Ilhom and Ott, Daniel and Hackl, Michael},
  title    = {PROMISING APPROACH FOR EXTENSION OF CAMBER SENSOR REGARDING LENGTHWISE AND CROSSWISE SPEED MEASUREMENT OF STRIP BETWEEN THE HOT STRIP FINISHING MILL STAND AND ITS BENEFIT FOR CONTROL STRATEGY},
  abstract = {State-of-the-art mill control for finishing mill section in hot strip mills are based on a
model of the entire process. The reason is that under the harsh circumstances not all necessary
measures can be made in this section. One example is the speed of the strip between the mill
stands. Due to an uncertain situation in the roll gap the geometry and with that the 
straightness, flatness and profile of the strip can only be predicted within certain limits. That
may lead to huge camber phenomenon sometimes resulting in so-called cobbles.
The used sensor is a simple optical measurement sensor mounted at the top of the mill
stand. The reliability of this sensor regarding the camber-, strip center position and width
measurement is already proven. Based on this technology the functionality could be expanded
to a strip speed measurement device. With that it is not only possible to measure the strip
speed in length direction (lengthwise) but also in crosswise direction. This second component
is of interest because this measure indicates the tendency of the strip drifting sideward.
Especially for the head end (looper angle and tension control is not yet available) this
information can be used in the mill control to improve the geometry of the strip and to avoid
camber and stand-stills due to cobbles.},
  file     = {:Hlobil/Hlobil.pdf:PDF},
  keywords = {Speed Measurement, HotStripMill,StripSteering, VisualStrip Measurement, RobustOptical Measurement, Camera System, Difference Tension, Robust PI-Control, Primetals},
}

@Article{Tachibana1987,
  author   = {H. Tachibana and A. Yamamoto and K. Matsui},
  journal  = {IFAC Proceedings Volumes},
  title    = {Shape Meter Using Image Processing Technology for Hot Rolling},
  year     = {1987},
  issn     = {1474-6670},
  note     = {10th Triennial IFAC Congress on Automatic Control - 1987 Volume II, Munich, Germany, 27-31 July},
  number   = {5, Part 2},
  pages    = {153-156},
  volume   = {20},
  abstract = {Recently development of new type rolling mills has made it possible to dynamically control the profile and the shape of hot rolled strips. In order to improve the performance of new type mills, profile and shape meters are required. The profile meter with high accuracy has been put to practical use, on the other hand the shape meter has not been widely used because of strip fluttering and the poor atmospheric conditions for example steam, dust and high temperature. Sumitomo Metals succeeded in developing a new shape meter with high accuracy applying laser and image processing technology. This system eliminates the measurement errors caused by the strip fluttering. Furthermore, it can be used even in the hot, steamy and dusty stomosphere. This system has been put into operation in the finishing mill of Kashima Steel Work’s hot strip mill and it has contributed to the improvement in the quality of hot strip coil.},
  doi      = {https://doi.org/10.1016/S1474-6670(17)55432-4},
  file     = {:Tachibana/Tachibana1987.pdf:PDF},
  keywords = {Steel industry, Sensor, Shape meter, Process control, Laser, Image processing technology},
  url      = {https://www.sciencedirect.com/science/article/pii/S1474667017554324},
}

@Article{Legrand,
  author   = {Legrand, N. and Swatch, K. and Peirera Santos, C.C. and Ehrlacher, A.},
  title    = {REVIEW OF SHAPEMETER ROLLS TECHNOLOGIES TO MEASURE STRIP SHAPE IN HOT AND COLD ROLLING CONDITIONS},
  abstract = {A Finite Element model has been developed to evaluate by simulation the capability of two
different segmented shape-meter roll technologies to measure flatness in hot and cold rolling.
These technologies generally measure the force distribution applied by the strip on roll
segments and an analytical equilibrium equation of force-tension to deduce strip flatness (e.g.
tension distribution across the strip width) from the force distribution. Simulations show that
high contact wrap angles, low strip tensions, heavy strip gages, high flatness defect 
amplitudes all produce attenuation of the measured flatness defect for the two technologies of
shape-rolls: defect amplitude detected by the shape-rolls appears under-estimated, till
sometimes 100%, in comparison to the real flatness defect present in the strip. It is shown that
this shape attenuation, confirmed by experiments, is due to the existence of shear stresses in
the strip near the roll-strip contact. Thus a modified analytical equilibrium equation of force-
tension is established to include these shear stresses to get a valid flatness defect evaluation by
the shape-roll over a wide range of tensions, gages, and wrap angles.},
  file     = {:Legrand/Legrand.pdf:PDF},
  keywords = {strip shape, flatness, residual stress, shape-roll, hot rolling, cold rolling, ArcelorMittal, Planheitsmessrolle, Planheit},
}

@Article{Liu2015,
  author   = {Liu, Shuang and Sun, Baoping and Zhao, Shuangshuang and Li, Jianxiong and Zhang, Wenming},
  journal  = {steel research international},
  title    = {Strongly Nonlinear Dynamics of Torsional Vibration for Rolling Mill's Electromechanical Coupling System},
  year     = {2015},
  number   = {9},
  pages    = {984-992},
  volume   = {86},
  abstract = {The torsional vibration often occurs during the rolling process, which will affect the production equipment. Based on electromagnetic field theory, the air gap magnetic field energy of salient pole synchronous motor was given, and the expression of electromagnetic torque was derived using the energy analysis method. In order to study the electromechanical coupling characteristics of the main drive system in rolling mill, a torsional vibration model with strongly nonlinear terms was established on the basis of mechanical dynamic principle. The periodic solutions of the strongly nonlinear torsional vibration system were obtained using the incremental harmonic balance (IHB) method. When the excitation force amplitude and the electromagnetic stiffness changed, the influence law on the torsional vibration characteristics of electromechanical coupling system under strongly nonlinear conditions was found. The effects of different electrical and mechanical parameters on the system amplitude-frequency property and vibration displacement characteristics were analyzed. All these research results are significant to structure design, parameter optimization and vibration control for the mill drive system.},
  doi      = {https://doi.org/10.1002/srin.201400216},
  eprint   = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/srin.201400216},
  file     = {:Liu/Liu2015.pdf:PDF},
  keywords = {main drive system of rolling mill, electromechanical coupling, strongly nonlinear, torsional vibration},
  url      = {https://onlinelibrary.wiley.com/doi/abs/10.1002/srin.201400216},
}

@Article{Sassmannshausen2016,
  author   = {Sassmannshausen, K. and Claus, R.},
  journal  = {AISTECH},
  title    = {Advanced Seal Development for HAGC, Bending Block and Work-Roll Applications},
  year     = {2016},
  abstract = {Technological advances in HAGC, bending block and work-roll cylinder control systems — intensified by increasingly more
aggressive operating parameters — have necessitated new developments in robust sealing systems. Key considerations include
extrusion resistance under higher pressures, guide band selection and accommodating larger extrusion gaps. This paper
explores new methods in advanced seal development including computer simulations through Finite Element Analysis,
experimental testing and data collection in the field.

Advancing control technology has created opportunities to implement more aggressive control schemes in order to better
control roll quality. One such advancement causes higher rod side pressures under typical operating cycles, which in turn,
creates more cylinder expansion, higher side loads, and bending deflections. This results in larger operating extrusion gaps.
Taken together, the larger gaps and the higher rod side pressures can push existing seal technology beyond its limits of
operation, resulting in extrusion.
Examples of such behavior can be observed in field inspected parts.
Additionally, these
examples show continued tendencies to extrude even over periods of time greater than initial break-in; on the order of
months. In the image below, the observed extrusion occurred under 25 MPa and .75mm nominal radial e-gap.

Older seal designs cannot effectively resist extrusion onset, due to larger e-gaps, higher pressures, and larger loads and
deflections. As a result, new designs are required. To reduce the time and costs required to go to market with a new design
capable of functioning in the more extreme operating conditions, a combination of both FEA and empirical experimentation
were used for this investigation.
As a result, a next generation rod seal was developed which can withstand the higher
pressures and e-gaps without extruding.
In conjunction, consideration was given to increases in e-gaps due to guidance system deflections and rod-to-cylinder eccentricity.
Furthermore, our design and simulation procedure included the impact
of temperature on extrusion resistance of materials, as determined by DMA testing data.
Therefore, cylinder manufactures
and engineers can design for larger e-gaps and clearances without the concern over seal extrusion and the associated system
failures.},
  file     = {:Sassmannshausen/Sassmannshausen2016.pdf:PDF},
  keywords = {HAGC Bending Block, Work-Roll, Extrusion},
}

