@Article{Pulcher,
  author   = {Pulcher, Theodor and Singh, Dennis and Drevermann, Jürgen and Deverient, Lutz and Evers, Christoph},
  title    = {A PRACTICAL EXAMPLE OF CONDITION MONITORING MEASURES TO MAINTAIN ROLLING CONDITIONS OF HOT -STRIP MILLS FOR HIGHEST CUSTOMER REQUIREMENTS},
  abstract = {Customer requirements have changed during the past years with respect to hot band by
cost reduction measures of the automotive industry by substituting of cold strip using hot strip
with nearly the same surface conditions.
The paper will show means to continuously identify deficiencies of rolling conditions,
especially in the finishing mill i.e. tailing out process, guiding according to centerline,
reducing the amount of leveling by operators. Demonstrating charts and photos will show the
mechanical effort of surveying all stands and aligning wear plates as well as roll chocks. The
amount of defects with respect to surface (roll marks, sticker), unplanned roll-changes, coil
shape before and after the mechanical modification will be shown.
Because of the increasing demands to surface quality, an online surface inspection
device is key to timely identify defects and necessary to check the impact of continuous
improving measures. In advance to the description of improving means and measures, a
general overview will be given to show the root cause of the various types of scale, which
occur in the finishing mill area. Furthermore, differences between producing with or without
coilbox with respect to scale are shown and valuable means to optimize the process producing
with coilbox are given.},
  file     = {:Pulcher/Pulcher.pdf:PDF},
  keywords = {rolling conditions on finishing mill, measurements, surveying stands, condition monitoring,surface defects on hot strip, thks, bochum},
}

@Article{Lang2017,
  author   = {Lang, O. and Stohl, K.},
  journal  = {Iron and Steel Technology},
  title    = {A new method for predictive maintenance for slow-rotating equipment},
  year     = {2017},
  month    = {09},
  pages    = {72-79},
  volume   = {14},
  abstract = {During the lifetime of a ladle
turret, the large swivel bearing
has to be replaced at least one
time. As this requires substantial
lead time, knowledge about
the condition of the bearing
is essential for optimized
planning. Regular grease
analyses and displacement/
tilt measurements are normal
predictive maintenance practices,
but deliver an incomplete
picture of the condition of the
bearing. Evaluation of shock
pulse measurements allows
for the first time a complete
picture and delivers accurate
information about the equipment.
This method is especially suited
for slow-rotating parts, but was
never before applied at
ladle turrets.},
  file     = {:Lang/Lang2017.pdf:PDF},
}

@Article{Shalaby2018,
  author   = {Shalaby, Ahmed and Haschke, Arno and Voglmeyer, Bernhard and Ringhofer, Markus},
  journal  = {stahl und eisen},
  title    = {Erhöhte Anlagenverfügbarkeit durch intelligentes Condition Monitoring System},
  year     = {2018},
  abstract = {Im Zuge der Bestrebungen, das Risiko von ungeplanten Stillstinden zu minimieren
und die Anlagenverfügbarkeit zu maximieren, setzen die Anlagenbetreiber der
Stahlindustrie die Maschinenwartung als oberste Prioritit. Somit wird eine zuverlassige
Zustandstüberwachung des Werks unausweichlich. Das entwickelte Condition Monitoring
System umfasst nicht nur die Uberwachung mechatronischer Systeme, sondern auch die
der technologischen Regelungen, von Prozessmodellen und Systemen von Drittanbietern.
Es ermöglicht eine Reduzierung der Wartungskosten.

Striving to minimize the risk of unplanned shutdowns and maximize plant availability, plant
operators of the steel industry have given the machine maintenance top priority. Thus a reliable
condition monitoring of the plant becomes inevitable. The developed condition monitoring system
includes the evaluation of mechatronic systems but it also comprises the evaluation of technological
controls, process models and third-party systems. It also enables to reduce the maintenance costs.},
  file     = {:Shalaby/Shalaby2018.pdf:PDF},
  keywords = {Primmetals},
}

@InProceedings{Binder2021,
  author    = {Binder, Daniel and Bendrat, Florian and Sourkounis, Constantinos},
  booktitle = {IECON 2021 – 47th Annual Conference of the IEEE Industrial Electronics Society},
  title     = {Model Predictive Control of a High Power Rolling-Mill Drive Considering Shaft Torque Constraints},
  year      = {2021},
  month     = {Oct},
  pages     = {1-7},
  abstract  = {Model Predictive Control enables the multi-objective optimization of mechatronic drive systems including the introduction of shaft torque constraints. In this paper, its practical application to a high power drive is discussed. This includes the controller design procedure, that particularly considers the limited torque dynamics of the controlled drive motor and state-estimation errors, that are counteracted by the implementation of soft constraints. As compromise between modelling errors and computational effort, the drive train is approximated as a three-mass model for state estimation and prediction. Simulative investigations indicate, that additional measures must be taken to achieve optimal results as the system performance is severely impacted by the observer’s dynamic reaction on plant perturbations and disturbances. Compared to a PI controller, the Model Predictive Control leads to reduced mechanical stress by decreasing the maximum shaft torques and suppressing the oscillations.},
  doi       = {10.1109/IECON48115.2021.9589315},
  file      = {:Binder/Binder2021.pdf:PDF},
  issn      = {2577-1647},
  keywords  = {Shafts;Torque;Perturbation methods;Computational modeling;Observers;Predictive models;Velocity measurement;Variable frequency drive;speed control;model predictive control;active damping;torsional oscillations;state constraints},
}

@InProceedings{Messer2016,
  author   = {Adrian Messer},
  title    = {Ultrasound Assisted Lubrication – Time Based to Condition Based},
  year     = {2016},
  abstract = {Airborne and Structure-borne ultrasound have evolved into a technology that many 
would consider to be the cornerstone of an effective maintenance and reliability 
program.  From compressed air and gas leak detection, electrical inspection, and 
various mechanical inspections, ultrasound is truly a versatile tool for anyone’s PdM 
"toolbox."  One application in particular utilizes the technology for condition based 
lubrication and to reduce lubrication related failures in rotating equipment. 
 
The most common causes of bearing failures are related to lubrication.  These failures 
happen because of either a lack of lubrication or too much lubrication.  Ultrasound 
assisted lubrication helps to take the guesswork out of how much lubricant to apply.  
Additionally, typical lubrication programs are based on timed intervals.  With time based 
lubrication, the tendency is to over lubricate.  Lubricant is applied at timed intervals 
whether the equipment needs to be greased or not.},
  file     = {:Messer/Messer2016.pdf:PDF},
}

