@Article{Bergmanna,
  author   = {Bergmann, M. and Mateja, F. and Olck, A.},
  title    = {Closing the loop of digitalization: From data generation to optimization of maintenance and operations in the metals industry},
  abstract = {For years, digitization has affected each industry and Industry 4.0 is on everyone's lips. With Bilfinger Digital Next
and the competence gained from decades of experience as industrial services provider, Bilfinger has set out to make
its digital solutions for the optimization of maintenance and operations available to the steel industry. The potential
_of optimization
is undoubtedly present:
with the help
of the latest artificial intelligence and machine learning
technology, individual use cases can be defined within the steel industry. Models are developed to monitor the
condition of individual machines with the help of virtual sensors that combine and evaluate all relevant plant data with
cloud solutions. Asset health monitoring, among a variety of additional solutions, allows deep insights improving
