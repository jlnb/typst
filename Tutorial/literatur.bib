@Unpublished{Zielenbach2024,
  author   = {Zielenbach, Michael},
  title    = {{Simulation Anstellung leichter Staucher}},
  year     = {2024},
  abstract = {Die dynamischen Eigenschaften der neuen leichten Staucher mit einem Anstell-
und zwei Balancierzylindern pro Walze werden hier mit Hilfe der Simulation analy-
siert.
Die Analyse zeigt, dass das vorgesehene Konzept umsetzbar ist. Bei der Ausle-
gung der Führungen sind die im ungünstigsten Fall auftretenden Kräfte zu beach-
ten.
Bei der Umsetzung sollten folgende Randbedingungen beachtet werden:
1. Der Druckgeber auf der Kolbenseite der Balancierzylinder muss am Zylin-
der sitzen.
2. Die Leitungslänge zwischen Ventilen und Zylindern sollte bei allen Zylin-
dern 6 m nicht überschreiten.
3. Für die Balancierzylinder sollte eine Positions- mit unterlagerter Kraftrege-
lung vorgesehen werden.
4. Die Abtastzeit der Regelung sollte 3 ms betragen
5. Die Kraftregelung muss eine Vorsteuerung aus der Geschwindigkeit des
VGC-Cylinders erhalten. Auch der VGC-Zylinder muss über diese Vorsteu-
erung verfügen.
6. Positionsabhängige Reglerverstärkung für Kraft- und Positionsregler der
Balancierzylinder.
7. Verfahren der Walze alleine mit der Positionsregelung der Balancierzylin-
der nur mit einem Kraftausgleichsregler.
8. Die Balancierkraft sollte 60 kN pro Zylinder betragen.},
  file     = {:Zielenbach/Zielenbach2024.pdf:PDF},
  keywords = {Staucher; Positionsabhängige Reglerverstärkung; gain scheduling; JSW-DO-EXT-N;},
}

