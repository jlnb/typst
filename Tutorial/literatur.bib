@Article{Hecht2017,
  author   = {Hecht, Michael},
  journal  = {stahl und eisen},
  title    = {Industrie 4.0 - der Dillinger Weg},
  year     = {2017},
  abstract = {Die mit dem Begriff Industrie 4.0 verbundenen Aktivititen und Technologien beginnen
die industriellen Produktionsprozesse, auch im Bereich der Stahlindustrie, immer
starker zu durchdringen. Der Umsetzungsweg ist fiir die Fertigungsindustrie, aufgrund
zahlreicher praktischer Beispiele in Publikationen und Medien, relativ klar vorgezeichnet.
Fiir die Stahlindustrie (als Prozessindustrie) muss noch erarbeitet werden, welche
Industrie-4.0-konformen Lésungen praktisch anwendbar sind und wie das Thema
allgemein, systematisch in die Prozesse iibertragen werden kann. Die AG der Dillinger
Hiittenwerke (Dillinger) hat damit begonnen, die Transformation hin zu einem Industrie-
4.0-Unternehmen gezielt und strukturiert voranzutreiben. In nachfolgendem Artikel
werden die ersten Schritte und Erfahrungen vorgestellt.

The idea of Indusirie 4.0 and its connected activities and technologies have started increasingly
influencing both industrial production in general and also the steel industry. For the manufacturing
industry the way to the realization of Industrie 4.0 is clearly visible, since there are plenty of
examples in literature, television and internet. In contrast, for the steel industry it still has to be
elaborated which ideas and solutions are practically applicable, how the topic can be tackled
systematically in general and how it can be introduced into the business processes. AG der Dillinger
Hiittenwerke (Dillinger) started the systematic transformation into an Indusirie 4.0 company lasi
year. The present paper describes the first steps and experiences.},
  file     = {:Hecht/Hecht2017.pdf:PDF},
}

@Article{Peters2016,
  author   = {Peters, Harald},
  journal  = {stahl und eisen},
  title    = {Industrie 4.0 in der Stahlindustrie aus Sicht der angewandten Forschung},
  year     = {2016},
  abstract = {Industrie 4.0 ist im Bereich der Automatisierungs- und Informationstechnik der
aktuelle Megatrend tiberhaupt. Auch die Stahl produzierenden Unternehmen stehen
derzeit vor der Frage, inwieweit heute die Weichen fiir die zukiinftige Nutzung
dieser Technologie gestellt werden miissen. Um diese Frage beantworten zu kénnen,
sollen zundchst die Grundkonzepte von Industrie 4.0 in die Welt der Stahlindustrie
tibertragen werden, um sie anschlieffend anhand von Beispielen, die in diesem Fall aus
Projekten der angewandten Forschung des VDEh-Betriebsforschungsinstituts stammen,
zu erlautern.

Industrie 4.0 is the main mega trend in the fields of process automation and information
technology. All steel producers are asking themselves if now the first steps towards the usage
of such technologies have to be taken to be prepared for the future. To answer this question
the basic concepts have first of all to be transferred into the world of steel production. After
that they should be explained by using project examples of applied research from the VDEh-
Betriebsforschungsinstitut.},
  file     = {:Peters/Peters2016.pdf:PDF},
}

@Article{Feist2016,
  author   = {Feist, Roger and Klinkov, Maksim},
  journal  = {elektorwärme international},
  title    = {Das virtuelle Walzwerk - wirksame Schritte zum Cyber Physical System},
  year     = {2016},
  abstract = {Hochste Produktivitét ist die grundlegende Erwartung von Walzwerksbetreibern Uberall auf der Welt. Dies impliziert
sowohl optimal laufende Prozesse als auch hochste Verfligbarkeit der Anlagen. Dabei entsteht eine Zwickmuhle: Die
zur Optimierung notwendigen Versuche an der laufenden Anlage geféhrden die Qualitat des Produktes oder sogar
die Produktionsanlage. Einen Ausweg aus diesem Dilemma bietet die ,virtuelle Maschine”. Sie bildet eine realitdtsnahe
Testumgebung fir unterschiedliche Szenarien und erméglicht damit eine risikoarme Lésungsentwicklung.

Highest productivity is the core expectation of mill operating companies all around the world. This implies both, pro-
cesses running in optimum condition and highest availability at the same time. A well-known dilemma is formed: The
necessary trials for optimization can jeopardize the quality of product or even the production line. The way out of this
dilemma is the use of a “virtual machine”. It offers a realistic test-environment for different scenarios and enhances low-
risk development of new efficient solutions.},
  file     = {:Feist/Feist2016.pdf:PDF},
}

