@MastersThesis{Hafer2025,
  author   = {Jannis Hafer},
  school   = {University of Siegen},
  title    = {{Systemidentifikation eines Hydraulikzylinders in einer Simulationsumgebung}},
  year     = {2025},
  month    = sep,
  abstract = {In dieser Arbeit wird eine Systemidentifikation zur Schätzung des Streckenverhaltens eines
Hydrauliksystems entwickelt, das aus Ventil, Rohrleitungen und Hubzylinder besteht. An-
stelle eines realen Systems steht lediglich ein nichtlineares SMS-internes Simulationsmo-
dell für die Bereitstellung von Trainingsdaten zur Verfügung. Dementsprechend erfolgt die
Ausarbeitung der Systemidentifikation vollständig in einer Simulationsumgebung, wobei
der Schwerpunkt auf der Bereitstellung der Trainingsdaten, der Struktur des Identifika-
tionsmodells, dem Optimierungssetup sowie der abschließenden Bewertung der Schätzung
liegt.
Als zentrales Resultat der Arbeit werden die Trainingsdaten im geschlossenen Regelkreis
mit einem linearisierten Zustandsraummodell erzeugt, wobei ein weiterentwickeltes und
angepasstes PRBS (engl. pseudo random binary signal) zur Anregung dient. Auf dieser
Basis wird ein Zustandsraummodell mit drei physikalisch interpretierbaren Parametern
geschätzt.
Weiterführend zu dieser Arbeit soll künftig mit der hier erarbeiteten Systemidentifikation
eine modellbasierte Einstellung der Regelparameter für ein Hydrauliksystem ermöglicht
werden.


In this thesis, a system identification is developed to estimate the plant behaviour of a
hydraulic system, which consists of a valve, pipes and a cylinder. Instead of a real system,
only a nonlinear SMS-internal simulation-model is available to provide training data. Due
to this, the whole elaboration takes place in a simulation environment with the focus
on the appropriation of the training data, the structure of the identification-model, the
optimization setup and the evaluation of the estimation.
As a central result of this thesis, the training data is generated in closed-loop with a lin-
earized state-space-model, where a developed and adapted PRBS (pseudo random binary
signal) is used for excitation. On this basis, a state-space-model with three physically
interpretable parameters is estimated.
The system identification developed here is intended to enable model-based tuning of
control parameters for the hydraulic system in the future.},
  file     = {:Hafer/Hafer2025.pdf:PDF},
  groups   = {Systemidentifikation},
  keywords = {Akte: 8744},
}

