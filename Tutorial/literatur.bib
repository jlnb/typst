@Article{Kampmeijer,
  author   = {Kampmeijer, L. and Dirkson, T. and Hol, C. and La Maire, M. and De Roo, J. and Schipper, G.},
  title    = {IMPROVED STRIP TRACKING WITH TAIL CONTROL IN HOTSTRIP ROLLING},
  abstract = {A notorious problem in the hot rolling process of flat products is poor strip tracking.
Most strip tracking issues appear at the head or the tail of the strip where the strip becomes
curved. Especially the tail-end can suddenly move sideward which may induce tail pinching.
To prevent such straightness defects we have developed a control that adjusts the differential
gap position during tailing out so that the predicted differential roll force is minimized.
Offline analysis shows that the control model provides a reasonably accurate prediction for
the tail behaviour. Moreover, results of production tests at Hot Strip Mill 2 in [Jmuiden as
presented in this paper, show that Tail Control leads to a considerable reduction of the
differential roll force. This clearly illustrates that Tail Control can be used to reduce level
errors and thus may contribute to a more stable rolling process.},
  file     = {:Kampmeijer/Kampmeijer.pdf:PDF},
  keywords = {Strip Tracking, Straightness Defects, Tail Pinching, Differential Gap Control, Hot StripRolling, Tata Ijmuiden},
}

@Article{Ogasahara2016,
  author   = {Tomoyoshi Ogasahara and Morten Hovd and Kazuya Asano},
  journal  = {IFAC-PapersOnLine},
  title    = {Explicit Model Predictive Controller Design for Thickness and Tension Control in a Cold Rolling Mill},
  year     = {2016},
  issn     = {2405-8963},
  note     = {17th IFAC Symposium on Control, Optimization and Automation in Mining, Mineral and Metal Processing MMM 2016},
  number   = {20},
  pages    = {126-131},
  volume   = {49},
  abstract = {Abstract:
This paper addresses modeling of a cold rolling mill and controller design based on explicit model predictive control(explicit MPC). The control objectives are to track the exit thickness to the reference with high accuracy with minimized strip tension deviation. In the simulation, good control is obtained when the disturbance entering the system is small enough. However, the thickness shows the offset from the reference in case of acceleration, because the approximation error of the linearized model increases and it is different from the model in the design of the controller. In order to compensate for the control offset, an additional integral logic using the estimation error of exit thickness is proposed. The validity of this approach was verified by simulation and offset free control was achieved.},
  doi      = {https://doi.org/10.1016/j.ifacol.2016.10.108},
  file     = {:Ogasahara/Ogasahara2016.pdf:PDF},
  keywords = {process control, process models, predictive control, optimal control, multi-input/multi-output system, steel industry},
  url      = {https://www.sciencedirect.com/science/article/pii/S2405896316316718},
}

@Article{Hol,
  author   = {Hol, C.W.J. and Bakker, G.T. and Boots, R.A. and Dieteren, W.H.A.M. and Jacobs, L.J.M. and Mandagi, N.S. and Ponsioen, J.IJ.J.H. and deRoo, J.J. and van de Lugt, J.},
  title    = {Recent developments in on-line setup and control of Tata Steel’s Cold Mills},
  abstract = {Tata Steel is one of the largest steel producers in the world. Tata Steel has several cold mills in Europe. Outstanding
process control of these mills is vital, as it determines to a large extent the off-gauge performance, shape performance
and mill throughput, and
it enables the rolling of new steel grades. The required rolling forces, torques, speeds,
reductions and powers are calculated at these cold mills using an online setup model. This model is an in-house
development of Tata Steel. It consists of a common core and mill-specific code in the shell. The setup application
contains sub-models for the material properties, roll flattening, friction and shape and profile. The desired setup is
calculated using an online optimization routine. New cold rolled products expand the well-known banana diagram,
towards higher formability in combination with higher strength. These grades are typically more difficult to produce,
stretching the capabilities of the mills. Furthermore, the product mix gets more and more varied and the cold mill
setup must be flexible enough to cope with these variations. New sensors are being developed and added to the
cold mill, which give extra information.
Finally, the mills are becoming interconnected with the upstream and
downstream process through more elaborate data communication. The recent developments to cope with these
trends are briefly addressed in this paper.},
  file     = {:Hol/Hol.pdf:PDF},
  keywords = {Cold Rolling, Setup, Deformation, Condition Monitoring, Industry 4.0, Tata Ijmuiden, Netherlands},
}

@Article{Qi2020,
  author   = {Qi, Jie-bin and Wang, Xin-xin and Yan, Xiao-qiang},
  journal  = {Journal of Iron and Steel Research International},
  title    = {Influence of mill modulus control gain on vibration in hot rolling mills},
  year     = {2020},
  issn     = {2210-3988},
  number   = {5},
  pages    = {528--536},
  volume   = {27},
  abstract = {The rolling mill vibration is characterized by the coupling effects among mechanical, electrical, hydraulic and interfacial subsystems. The influence of the mill modulus control gain in automatic gauge control on the vibration in hot rolling mills was investigated. Firstly, an experiment related to the mill modulus control gain was carried out in the hot rolling mill process, and it was found that the rolling mill vibration increases with the mill modulus control gain. Then, based on the Sims rolling force method, the coupling dynamic model was established to explain this phenomenon. Finally, the influence of mill modulus control gain on the vibration was analyzed numerically on the basis of the coupling dynamic model. Moreover, the agreement between the experimental results and the simulation results was confirmed and the measure reducing the mill modulus control gain was obtained to relieve mill vibration.},
  doi      = {10.1007/s42243-020-00375-3},
  file     = {:Qi/Qi2020.pdf:PDF},
  refid    = {Qi2020},
  url      = {https://doi.org/10.1007/s42243-020-00375-3},
}

